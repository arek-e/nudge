{
  "plugins": ["typescript", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-underscore-dangle": ["warn", { "allow": ["_id"] }],
    "import/no-duplicates": "error"
  },
  "ignorePatterns": ["node_modules/**", ".tsbuild/**", ".wrangler/**"]
}
