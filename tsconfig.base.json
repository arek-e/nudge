{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["@cloudflare/workers-types"],
    "baseUrl": ".",
    "paths": {
      "@lares/domain": ["packages/domain/src/index.ts"],
      "@lares/effect-services": ["packages/effect-services/src/index.ts"],
      "@lares/engine-contract": ["packages/engine-contract/src/index.ts"],
      "@lares/db": ["packages/db/src/index.ts"],
      "@lares/evals": ["packages/evals/src/index.ts"],
      "@lares/observability": ["packages/observability/src/index.ts"],
      "@lares/ui": ["packages/ui/src/index.tsx"]
    }
  }
}
