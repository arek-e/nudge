{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["@cloudflare/workers-types"],
    "baseUrl": ".",
    "paths": {
      "@personal-agent-os/domain": ["packages/domain/src/index.ts"],
      "@personal-agent-os/effect-services": ["packages/effect-services/src/index.ts"],
      "@personal-agent-os/db": ["packages/db/src/index.ts"],
      "@personal-agent-os/evals": ["packages/evals/src/index.ts"]
    }
  }
}
