{
  "name": "@lares/engine",
  "private": true,
  "type": "module",
  "scripts": {
    "cf-typegen": "wrangler types",
    "db:migrations:apply:local": "wrangler d1 migrations apply DB --local",
    "db:migrations:apply:remote": "wrangler d1 migrations apply DB --remote",
    "deploy": "bun ../../scripts/deploy-engine.ts",
    "deploy:dirty": "bun ../../scripts/deploy-engine.ts --allow-dirty",
    "deploy:dry-run": "bun ../../scripts/deploy-engine.ts --dry-run",
    "deploy:production": "bun ../../scripts/deploy-engine.ts --env=production",
    "deploy:staging": "bun ../../scripts/deploy-engine.ts --env=staging",
    "dev": "bun ../../scripts/dev-engine.ts",
    "dev:remote": "bun ../../scripts/dev-engine.ts --remote",
    "logs:tail": "wrangler tail lares-web --format=json",
    "logs:tail:pretty": "wrangler tail lares-web --format=pretty",
    "traces:recent": "wrangler d1 execute DB --remote --command \"SELECT timestamp, event, route_name, path, status, outcome, duration_ms, sample_reason FROM trace_events ORDER BY created_at DESC LIMIT 20\"",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "catalog:",
    "@better-auth/passkey": "catalog:",
    "@cloudflare/sandbox": "catalog:",
    "@cloudflare/think": "catalog:",
    "@lares/db": "workspace:*",
    "@lares/domain": "workspace:*",
    "@lares/effect-services": "workspace:*",
    "@lares/engine-contract": "workspace:*",
    "@lares/evals": "workspace:*",
    "@lares/observability": "workspace:*",
    "@modelcontextprotocol/sdk": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "agents": "catalog:",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "evlog": "catalog:",
    "hono": "catalog:",
    "workers-ai-provider": "catalog:",
    "zod": "catalog:"
  }
}
