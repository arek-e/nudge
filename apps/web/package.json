{
  "name": "@vesta/web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "db:migrations:apply:local": "wrangler d1 migrations apply DB --local",
    "db:migrations:apply:remote": "wrangler d1 migrations apply DB --remote",
    "deploy": "bun ../../scripts/deploy-web.ts",
    "deploy:dirty": "bun ../../scripts/deploy-web.ts --allow-dirty",
    "deploy:dry-run": "bun ../../scripts/deploy-web.ts --dry-run",
    "deploy:production": "bun ../../scripts/deploy-web.ts --env=production",
    "deploy:staging": "bun ../../scripts/deploy-web.ts --env=staging",
    "dev": "bun ../../scripts/dev-web.ts",
    "dev:remote": "bun ../../scripts/dev-web.ts --remote",
    "logs:tail": "wrangler tail vesta-web --format=json",
    "logs:tail:pretty": "wrangler tail vesta-web --format=pretty",
    "test:e2e": "playwright test",
    "traces:recent": "wrangler d1 execute DB --remote --command \"SELECT timestamp, event, route_name, path, status, outcome, duration_ms, sample_reason FROM trace_events ORDER BY created_at DESC LIMIT 20\"",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@clerk/backend": "catalog:",
    "@clerk/react": "catalog:",
    "@cloudflare/sandbox": "catalog:",
    "@cloudflare/think": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "@orpc/client": "catalog:",
    "@orpc/contract": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/openapi-client": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@vesta/db": "workspace:*",
    "@vesta/domain": "workspace:*",
    "@vesta/effect-services": "workspace:*",
    "@vesta/evals": "workspace:*",
    "@vesta/observability": "workspace:*",
    "@vesta/ui": "workspace:*",
    "agents": "catalog:",
    "ai": "catalog:",
    "braintrust": "3.20.0",
    "convex": "catalog:",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "evlog": "catalog:",
    "hono": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "workers-ai-provider": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "vite": "catalog:",
    "vite-plugin-pwa": "catalog:"
  }
}
