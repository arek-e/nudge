{
  "name": "@nudge/web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "deploy": "bun ../../scripts/deploy-web.ts",
    "deploy:dirty": "bun ../../scripts/deploy-web.ts --allow-dirty",
    "deploy:dry-run": "bun ../../scripts/deploy-web.ts --dry-run",
    "deploy:production": "bun ../../scripts/deploy-web.ts --env=production",
    "deploy:staging": "bun ../../scripts/deploy-web.ts --env=staging",
    "dev": "bun ../../scripts/dev-web.ts",
    "dev:remote": "bun ../../scripts/dev-web.ts --remote",
    "logs:tail": "wrangler tail nudge-web --format=json",
    "logs:tail:pretty": "wrangler tail nudge-web --format=pretty",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@clerk/backend": "catalog:",
    "@clerk/react": "catalog:",
    "@cloudflare/sandbox": "catalog:",
    "@cloudflare/think": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "@nudge/ai": "workspace:*",
    "@nudge/db": "workspace:*",
    "@nudge/db-convex": "workspace:*",
    "@nudge/domain": "workspace:*",
    "@nudge/effect-services": "workspace:*",
    "@nudge/evals": "workspace:*",
    "@nudge/observability": "workspace:*",
    "@nudge/surface": "workspace:*",
    "@nudge/ui": "workspace:*",
    "@orpc/client": "catalog:",
    "@orpc/contract": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/openapi-client": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@sentry/cloudflare": "^10.63.0",
    "@sentry/hono": "^10.63.0",
    "@sentry/react": "^10.63.0",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "agents": "catalog:",
    "ai": "catalog:",
    "braintrust": "3.20.0",
    "convex": "catalog:",
    "effect": "catalog:",
    "evlog": "catalog:",
    "hono": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:"
