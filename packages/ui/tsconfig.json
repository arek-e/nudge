{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "jsx": "react-jsx",
    "outDir": "../../.tsbuild/packages/ui",
    "paths": {
      "@/*": ["src/*"]
    },
    "rootDir": "src",
    "tsBuildInfoFile": "../../.tsbuild/packages/ui.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
